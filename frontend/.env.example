# Backend API base URL (default: http://localhost:8000)
VITE_API_URL=http://localhost:8000

# Google OAuth 2.0 Client ID (Web application) for "Import from Google Drive".
# Create in Google Cloud Console: APIs & Services → Credentials → Create OAuth 2.0 Client ID.
# Enable Google Drive API and (for Picker) ensure the consent screen is configured.
# Copy to .env.local and set your real client ID.
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
